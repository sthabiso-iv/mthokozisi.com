# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# Also add these to Vercel: Settings > Environment Variables

# ── Resend (contact form email delivery) ──────────────────────────────
# 1. Sign up at https://resend.com (free tier: 3,000 emails/month)
# 2. Create an API key at https://resend.com/api-keys
# 3. Verify your domain at https://resend.com/domains (add DNS TXT + MX records)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Email addressing ───────────────────────────────────────────────────
# The address you want to receive contact form messages at
EMAIL_TO=hello@mthokozisi.com

# The "from" address on outgoing emails.
# Must match a domain verified in your Resend account.
# Until domain is verified, use: onboarding@resend.dev
EMAIL_FROM=noreply@mthokozisi.com

# Display name shown in the recipient's inbox (e.g. "Mthokozisi Dhlamini")
EMAIL_FROM_NAME=Mthokozisi Dhlamini

# ── On-demand cache revalidation ──────────────────────────────────────
# A random secret used to authenticate the /api/revalidate endpoint.
# Generate one with: openssl rand -hex 32
REVALIDATE_SECRET=a0f11231e449a20c7e032bfe23ad19c566f7960b684ea2cad41df3203a6b0e34
